// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ShipmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ShipmentType {
  IMPORT
  EXPORT
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Shipment {
  id              String         @id @default(uuid())
  jobNo           String         @unique
  blNo            String
  consignee       String
  shipper         String
  vessel          String
  portOfLoading   String
  portOfDischarge String
  eta             DateTime
  etd             DateTime
  etb             DateTime?
  openCy          DateTime?
  closeSi         DateTime?
  closeCy         DateTime?
  type            ShipmentType   @default(IMPORT)
  currentStep     Int            @default(0) // Matches your current Int setup
  nextAction      String         @default("Check ETA & Port") // <-- ADD THIS LINE HERE
  status          ShipmentStatus @default(ACTIVE)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tasks        ShipmentTask[]
  reminders    Reminder[]
  activityLogs ActivityLog[]
  todos        Todo[]

  @@index([status])
  @@index([eta])
  @@index([jobNo])
}

model ActivityLog {
  id         String   @id @default(uuid())
  shipmentId String
  message    String
  createdAt  DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([createdAt])
}

model ShipmentTask {
  id          String    @id @default(uuid())
  shipmentId  String
  title       String
  stepOrder   Int
  completed   Boolean   @default(false)
  completedAt DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@unique([shipmentId, stepOrder])
  @@index([shipmentId])
}

model Reminder {
  id         String   @id @default(uuid())
  shipmentId String
  title      String
  dueDate    DateTime
  completed  Boolean  @default(false)
  priority   Priority @default(MEDIUM)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([completed, dueDate])
}

model Todo {
  id         String   @id @default(uuid())
  shipmentId String
  text       String
  isDone     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
}

model DailyTodo {
  id        String   @id @default(uuid())
  text      String
  isDone    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TerminalMonitor {
  id          String   @id @default(uuid())
  containerNo String   @unique
  port        String   @default("jict")
  status      String   @default("ONVSL")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}
